{
  "name": "@near/near-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "next dev --port 3001",
    "postinstall": "prisma generate --schema=./packages/cms-core/prisma/schema.prisma",
    "build": "prisma generate --schema=./packages/cms-core/prisma/schema.prisma && prisma db push --schema=./packages/cms-core/prisma/schema.prisma --skip-generate && next build",
    "start": "next start",
    "lint": "next lint",
    "prisma:migrate": "prisma migrate dev --schema=./packages/cms-core/prisma/schema.prisma",
    "prisma:seed": "node packages/cms-core/prisma/seed.ts",
    "prisma:studio": "prisma studio --schema=./packages/cms-core/prisma/schema.prisma"
  },
  "dependencies": {
    "@near/cms-core": "workspace:*",
    "next": "^16.1.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.0.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.5.0",
    "lucide-react": "^0.576.0",
    "gsap": "^3.15.0",
    "lenis": "^1.3.23",
    "react-icons": "^5.6.0",
    "feed": "^4.2.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "postcss": "^8.5.8",
    "shadcn": "^3.8.5",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3"
  }
}
