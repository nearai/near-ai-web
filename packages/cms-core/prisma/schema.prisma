generator client {
  provider      = "prisma-client-js"
  output        = "../../../node_modules/.prisma/client"
  binaryTargets = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  name            String
  role            Role     @default(EDITOR)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastLoginAt     DateTime?
  pages           Page[]   @relation("PageAuthor")
  lastEditedPages Page[]   @relation("PageLastEditor")
  posts           Post[]   @relation("PostAuthor")
  lastEditedPosts Post[]   @relation("PostLastEditor")
  banners         Banner[] @relation("BannerAuthor")
}

model Post {
  id                 String     @id @default(cuid())
  title              String
  slug               String     @unique
  content            Json
  excerpt            String?
  coverImage         String?
  status             Status     @default(DRAFT)
  seoTitle           String?
  seoDesc            String?
  ogImage            String?
  authorId           String
  publishedAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  heroBgColor        String?
  heroBgImage        String?
  lastEditedById     String?
  lockedAt           DateTime?
  lockedBy           String?
  lockedByEmail      String?
  previewPassword    String?
  previewToken       String?    @unique
  excludeFromSitemap Boolean    @default(false)
  author             User       @relation("PostAuthor", fields: [authorId], references: [id])
  lastEditedBy       User?      @relation("PostLastEditor", fields: [lastEditedById], references: [id])
  categories         Category[] @relation("CategoryToPost")
  tags               Tag[]      @relation("PostToTag")
}

model Page {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  content          Json
  status           Status   @default(DRAFT)
  seoTitle         String?
  seoDesc          String?
  ogImage          String?
  authorId         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastEditedById   String?
  publishedAt      DateTime?
  excludeFromSitemap Boolean @default(false)
  author           User     @relation("PageAuthor", fields: [authorId], references: [id])
  lastEditedBy     User?    @relation("PageLastEditor", fields: [lastEditedById], references: [id])
}

model Banner {
  id                 String            @id @default(cuid())
  name               String
  type               BannerType        @default(TOP)
  paths              String[]          @default([])
  enabled            Boolean           @default(false)
  frequency          BannerFrequency   @default(ALWAYS)
  contentMode        BannerContentMode @default(HTML)
  content            Json?
  htmlContent        String?
  modalDelaySeconds  Int?
  modalScrollPercent Int?
  modalPosition      BannerModalPosition @default(CENTER)
  displayMode        BannerDisplayMode @default(OVERLAY)
  startDate          DateTime?
  endDate            DateTime?
  viewCount          Int               @default(0)
  clickCount         Int               @default(0)
  dismissCount       Int               @default(0)
  authorId           String
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  author             User              @relation("BannerAuthor", fields: [authorId], references: [id])

  @@index([enabled])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  filename  String
  mimeType  String
  size      Int
  alt       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[] @relation("CategoryToPost")
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[] @relation("PostToTag")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model InvitationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  name      String
  role      Role     @default(EDITOR)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model FormSubmission {
  id        String   @id @default(cuid())
  formId    String
  data      Json
  status    String   @default("NEW")
  createdAt DateTime @default(now())

  @@index([formId])
  @@index([createdAt])
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  userEmail   String
  action      String
  entityType  String
  entityId    String
  entityTitle String
  createdAt   DateTime @default(now())
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum Status {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BannerType {
  TOP
  MODAL
  BOTTOM
}

enum BannerFrequency {
  ALWAYS
  ONCE_PER_SESSION
  DONT_SHOW_AGAIN
}

enum BannerContentMode {
  EDITOR
  HTML
}

enum BannerModalPosition {
  TOP_LEFT
  TOP_CENTER
  TOP_RIGHT
  CENTER_LEFT
  CENTER
  CENTER_RIGHT
  BOTTOM_LEFT
  BOTTOM_CENTER
  BOTTOM_RIGHT
}

enum BannerDisplayMode {
  OVERLAY
  PUSH
}
