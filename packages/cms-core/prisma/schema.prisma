generator client {
  provider = "prisma-client-js"
  output   = "../../../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  password        String
  name            String
  role            Role     @default(EDITOR)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  lastLoginAt     DateTime?
  pages           Page[]   @relation("PageAuthor")
  lastEditedPages Page[]   @relation("PageLastEditor")
  posts           Post[]   @relation("PostAuthor")
  lastEditedPosts Post[]   @relation("PostLastEditor")
}

model Post {
  id                 String     @id @default(cuid())
  title              String
  slug               String     @unique
  content            Json
  excerpt            String?
  coverImage         String?
  status             Status     @default(DRAFT)
  seoTitle           String?
  seoDesc            String?
  ogImage            String?
  authorId           String
  publishedAt        DateTime?
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt
  heroBgColor        String?
  heroBgImage        String?
  lastEditedById     String?
  lockedAt           DateTime?
  lockedBy           String?
  lockedByEmail      String?
  previewPassword    String?
  previewToken       String?    @unique
  excludeFromSitemap Boolean    @default(false)
  author             User       @relation("PostAuthor", fields: [authorId], references: [id])
  lastEditedBy       User?      @relation("PostLastEditor", fields: [lastEditedById], references: [id])
  categories         Category[] @relation("CategoryToPost")
  tags               Tag[]      @relation("PostToTag")
}

model Page {
  id               String   @id @default(cuid())
  title            String
  slug             String   @unique
  content          Json
  status           Status   @default(DRAFT)
  seoTitle         String?
  seoDesc          String?
  ogImage          String?
  authorId         String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastEditedById   String?
  publishedAt      DateTime?
  excludeFromSitemap Boolean @default(false)
  author           User     @relation("PageAuthor", fields: [authorId], references: [id])
  lastEditedBy     User?    @relation("PageLastEditor", fields: [lastEditedById], references: [id])
}

model Media {
  id        String   @id @default(cuid())
  url       String
  filename  String
  mimeType  String
  size      Int
  alt       String?
  createdAt DateTime @default(now())
}

model Category {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[] @relation("CategoryToPost")
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  posts Post[] @relation("PostToTag")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model InvitationToken {
  id        String   @id @default(cuid())
  token     String   @unique
  email     String
  name      String
  role      Role     @default(EDITOR)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String
  userEmail   String
  action      String
  entityType  String
  entityId    String
  entityTitle String
  createdAt   DateTime @default(now())
}

enum Role {
  ADMIN
  EDITOR
  VIEWER
}

enum Status {
  DRAFT
  PUBLISHED
  ARCHIVED
}
